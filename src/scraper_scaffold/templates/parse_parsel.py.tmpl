"""Parse layer for __PROJECT_NAME__ (parsel / CSS + XPath).

This is an *example* extractor. Replace the selectors in :func:`parse_items`
with ones that match the site you are scraping.
"""

from __future__ import annotations

from urllib.parse import urljoin

from parsel import Selector


def page_title(html: str) -> str:
    """Return the document ``<title>``, or an empty string."""
    return (Selector(text=html).css("title::text").get() or "").strip()


def parse_items(html: str, base_url: str = "") -> list[dict[str, str]]:
    """Extract a list of rows from *html*.

    The default implementation pulls every hyperlink with its visible text and
    resolves relative URLs against *base_url* — a sensible, site-agnostic
    starting point you can specialize.
    """
    selector = Selector(text=html)
    rows: list[dict[str, str]] = []
    for anchor in selector.css("a"):
        href = anchor.css("::attr(href)").get()
        text = " ".join(anchor.css("::text").getall()).strip()
        if not href or not text:
            continue
        rows.append({"text": text, "url": urljoin(base_url, href)})
    return rows

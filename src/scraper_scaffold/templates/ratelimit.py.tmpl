"""A small, dependency-free token-bucket rate limiter.

It smooths request bursts to a sustained ``rate`` (requests/second) and also
honors a hard minimum interval between requests — which is exactly what a
robots.txt ``Crawl-delay`` maps to.

Both a blocking :meth:`RateLimiter.acquire` and an async
:meth:`RateLimiter.acquire_async` are provided so the same limiter works in
sync and async scrapers.
"""

from __future__ import annotations

import asyncio
import threading
import time


class RateLimiter:
    """Token bucket with an optional minimum inter-request interval."""

    def __init__(self, rate: float, burst: int = 1) -> None:
        if rate <= 0:
            raise ValueError("rate must be > 0")
        self.rate = float(rate)
        self.capacity = max(1, int(burst))
        self._tokens = float(self.capacity)
        self._updated = time.monotonic()
        self._next_allowed = self._updated
        self._min_interval = 0.0
        self._lock = threading.Lock()

    def set_min_interval(self, seconds: float) -> None:
        """Enforce at least *seconds* between requests (e.g. a Crawl-delay)."""
        self._min_interval = max(self._min_interval, max(0.0, seconds))

    def _reserve(self) -> float:
        """Reserve one request and return how long the caller must wait (s)."""
        with self._lock:
            now = time.monotonic()
            elapsed = now - self._updated
            self._updated = now
            self._tokens = min(self.capacity, self._tokens + elapsed * self.rate)

            wait = 0.0
            if self._tokens < 1.0:
                wait = (1.0 - self._tokens) / self.rate
            self._tokens -= 1.0

            # Honor the hard minimum interval between successive requests.
            start = max(now + wait, self._next_allowed)
            wait = start - now
            self._next_allowed = start + self._min_interval
            return max(0.0, wait)

    def acquire(self) -> None:
        """Block until a request is permitted."""
        wait = self._reserve()
        if wait > 0:
            time.sleep(wait)

    async def acquire_async(self) -> None:
        """Asynchronously wait until a request is permitted."""
        wait = self._reserve()
        if wait > 0:
            await asyncio.sleep(wait)

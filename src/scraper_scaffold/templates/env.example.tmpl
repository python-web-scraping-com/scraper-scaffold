# Copy to .env and adjust. Every value is optional; defaults live in settings.py.

# Identify your bot honestly — put a real contact URL or email here.
USER_AGENT=__USER_AGENT__

# Politeness controls.
REQUESTS_PER_SECOND=1.0
BURST=1
TIMEOUT=20.0
MAX_RETRIES=3
OBEY_ROBOTS=true

# On-disk HTTP cache.
CACHE_ENABLED=__CACHE_DEFAULT_ENV__
CACHE_DIR=.http_cache
CACHE_TTL=0

# Optional proxy, e.g. http://user:pass@host:port
PROXY=

# Output & logging.
OUTPUT_DIR=output
LOG_LEVEL=INFO

# Comma-separated list of URLs to start from.
START_URLS=https://quotes.toscrape.com/
